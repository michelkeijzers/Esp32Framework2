@startuml 

legend
|= Color |= Type |= Meaning |
|<back:lightblue>           | App Specific | Components specific to the application, containing the main logic.|
|<back:lightgreen>           | Common       | Generic, reusable components across different applications.|
endlegend

package Project_Package
{
    class MainCpp #lightblue {}
    class RtosTask<<abstract>> #lightgreen {}
    class Node<<abstract>> #lightgreen {}

    'Master Node 
    package MasterNode_Package 
    {
        class MasterNode <<Node>> #lightblue {}
        
        class MasterBridge <<RtosTask>> #lightgreen {}
        MasterNode *-- MasterBridge

        note bottom of MasterBridge
            Remote Proxy
            Design Pattern 
        end note

        class MasterTask <<RtosTask>> #lightblue {}

        MasterNode *-- MasterTask

        MasterNode *-- WebServerTask

        class WebServerTask <<RtosTask>> #lightblue {}
        MasterTask <--> WebServerTask

        class _Application_Task <<RtosTask>> #lightblue {}
        note bottom of _Application_Task
            Placeholder for 
            application 
            specific 
            task(s)
        end note
        MasterNode *-- _Application_Task
        MasterTask <--> _Application_Task
        
        class ApiServer #lightblue {}
        WebServerTask *-- ApiServer
    }

    MainCpp *-- MasterNode

    'Slave Node
    package SlaveNode_Package
    {
        class SlaveBridge <<RtosTask>> #lightgreen {}
        note bottom of SlaveBridge
            Remote Proxy
            Design Pattern 
        end note

        class SlaveNode <<Node>> #lightgreen {}

        SlaveNode *-- SlaveBridge

        ' Slave Task
        class SlaveTask <<RtosTask>> #lightgreen {}
        SlaveNode *-- SlaveTask
    }

    MainCpp *-- "0..*"SlaveNode

    MasterBridge .. SlaveBridge : Direct or \n ESP-NOW

    package ServiceTasks_Package 
    {
        class ServiceTask <<abstract, RtosTask>> #lightgreen {}

        class ServiceTasks #lightgreen {}
        class MasterServiceTasks #lightgreen {}
        class SlaveServiceTasks #lightgreen {}

        MasterServiceTasks --|> ServiceTasks
        SlaveServiceTasks --|> ServiceTasks

        class LoggingTask <<ServiceTask>> #lightgreen {}
        class StatusTask <<ServiceTask>> #lightgreen {}
        class OtaTask <<ServiceTask>> #lightgreen {}

        LoggingTask --|> ServiceTask
        StatusTask --|> ServiceTask
        OtaTask --|> ServiceTask

        MasterServiceTasks *-- StatusTask
        ServiceTasks *-- LoggingTask
        ServiceTasks *-- OtaTask
    }

    package FunctionTasks_Package
    {
        class FunctionTasks #lightgreen {}
    }

    MasterNode *-- "0..*" FunctionTasks
    SlaveNode  *-- "1..*" FunctionTasks
    MasterTask <-> MasterBridge

    MasterNode *---- MasterServiceTasks
    SlaveNode *---- SlaveServiceTasks
    SlaveTask <-> SlaveBridge
}

@enduml

