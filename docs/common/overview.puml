    ShiftRegisterInputOutputPinsTask --|> InputOutputPinsTask
    class Mcp23017InputOutputPinsTask #lightgreen {}
    Mcp23017InputOutputPinsTask --|> InputOutputPinsTask
    DigitalInputChannel *-- "0..64" ShiftRegisterInputOutputPinsTask
    DigitalOutputChannel *-- "0..64" ShiftRegisterInputOutputPinsTask
    DigitalInputChannel *-- "0..64" Mcp23017InputOutputPinsTask
    DigitalOutputChannel *-- "0..64" Mcp23017InputOutputPinsTask

