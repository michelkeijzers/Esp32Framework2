    class DmxMax3485Task #lightgreen {}
    DmxMax3485Task --|> FunctionTask

    class MidiTask #lightgreen {}
    MidiTask --|> FunctionTask

    class RelaisTask #lightgreen {}
    RelaisTask --|> FunctionTask
    class RelaisChannel #lightgreen {}
    RelaisTask *-- "0..8" RelaisChannel

    class GasSensorTask #lightgreen {}
    GasSensorTask --|> FunctionTask
    
    FunctionTasks *- "0..*"FunctionTask
}

