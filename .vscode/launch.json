{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Linux Debug AppMainIntegrationTest",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/tests/build/integration_tests/integration_tests",
      "args": [
        "--gtest_filter=AppMainIntegrationTest.AppMainInitializesAndStartsTopLevelFlow"
      ],
      "cwd": "${workspaceFolder}/tests/build/integration_tests",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "stopAtEntry": true,
      "externalConsole": false,
      "preLaunchTask": "Build (F7)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
